{% comment %}
  =====================================================================
  Ecommerce Tracking IA — Shopify Snippet  v3.9
  Arquivo: snippets/et-tracker.liquid

  INSTALAÇÃO:
  1. Copie este arquivo para: snippets/et-tracker.liquid
  2. Em layout/theme.liquid, adicione ANTES de </body>:
       {% render 'et-tracker' %}

  Canais ativos (browser + CAPI server-side):
  - Meta Pixel  — fbp/fbc, dedup via event_id
  - TikTok Pixel — ttclid/_ttp, ttq.page() automático
  - Pinterest Tag — epik, pintrk('page') automático
  - Google Ads   — gclid/gbraid/wbraid (iOS 14+)

  Eventos rastreados:
  - pageview / PageView / pagevisit
  - product_viewed / ViewContent / viewitem
  - add_to_cart / AddToCart / addtocart
  - checkout_started / InitiateCheckout / checkout
  - purchase / Purchase / checkout  (thank-you page, dedup SHA-256)

  Cart attributes injetados (atravessam gateways PIX/externos):
  - _etv, _fbp, _fbc, _gcid, _gclid, _gbraid, _wbraid
  - _ettc (ttclid), _ttp, _epik
  - _fblogin, _dob
  - _utm_source/medium/campaign/content/term

  v3.9 vs v3.8: cache de leitura de cookie/storage por página
  (evita múltiplas leituras do DOM para o mesmo identificador).
  =====================================================================
{% endcomment %}

<script>
(function (w, d) {
  'use strict';

  // ── Configuração ────────────────────────────────────────────────────────────
  var CLIENT_ID        = 'lk-sneakers';
  var API_URL          = 'https://track.lksneakers.com.br';
  var META_PIXEL_ID    = '1018779385487104';
  var GOOGLE_ADS_AW_ID = '';
  var TIKTOK_PIXEL_ID  = 'D8Q3UBJC77U2I8M6LR50';
  var PINTEREST_TAG_ID = '2613108888112';

  var COOKIE_VISITOR  = '_etv';
  var COOKIE_ATTR     = '_eta';
  var STORAGE_SESSION = '_ets';

  // ── Cache de identificadores (1 leitura por página) ──────────────────────────
  // Evita múltiplos document.cookie.match() para o mesmo campo numa mesma sessão.
  // Não cacheamos _ttp porque o TikTok pixel o seta de forma assíncrona — cacheá-lo
  // no primeiro evento (pageview) fixaria null antes do pixel terminar de carregar.
  var _C = {};
  function _c(k, fn) { return (k in _C) ? _C[k] : (_C[k] = fn()); }

  // ── Cookies ──────────────────────────────────────────────────────────────────
  function setCookie(name, value, days) {
    var expires = '';
    if (days) {
      var exp = new Date();
      exp.setTime(exp.getTime() + days * 864e5);
      expires = '; expires=' + exp.toUTCString();
    }
    // Browsers reject cookies whose domain is a public suffix (com.br, co.uk).
    // The old logic `slice(-2)` produced exactly that on Brazilian stores and
    // the cookie silently vanished, regenerating _etv on every pageview.
    var domain = '';
    try {
      var host = location.hostname;
      if (host && host.indexOf('.') !== -1 && !/^\d+(\.\d+)+$/.test(host)) {
        var parts = host.split('.');
        var twoSegTlds = {
          'com.br': 1, 'co.uk': 1, 'co.jp': 1, 'co.kr': 1, 'co.in': 1,
          'com.au': 1, 'com.ar': 1, 'com.mx': 1, 'com.co': 1, 'com.pe': 1,
          'com.sg': 1, 'com.hk': 1, 'com.tw': 1, 'com.tr': 1, 'com.ua': 1
        };
        var lastTwo = parts.slice(-2).join('.');
        if (twoSegTlds[lastTwo] && parts.length >= 3) {
          domain = '; domain=.' + parts.slice(-3).join('.');
        } else if (parts.length >= 2) {
          domain = '; domain=.' + lastTwo;
        }
      }
    } catch (e) {}
    d.cookie = name + '=' + encodeURIComponent(value) + expires + '; path=/' + domain + '; SameSite=Lax';
    if (domain) {
      try {
        if (d.cookie.indexOf(name + '=') === -1) {
          d.cookie = name + '=' + encodeURIComponent(value) + expires + '; path=/; SameSite=Lax';
        }
      } catch (e) {}
    }
  }

  function getCookie(name) {
    var match = d.cookie.match(new RegExp('(?:^|;\\s*)' + name + '=([^;]*)'));
    return match ? decodeURIComponent(match[1]) : null;
  }

  // ── UUID ─────────────────────────────────────────────────────────────────────
  function uuid() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      var r = (Math.random() * 16) | 0;
      return (c === 'x' ? r : (r & 0x3) | 0x8).toString(16);
    });
  }

  // ── Visitor / Session IDs ─────────────────────────────────────────────────────
  function getVisitorId() {
    return _c('vid', function() {
      var vid = getCookie(COOKIE_VISITOR);
      if (!vid) { vid = uuid(); setCookie(COOKIE_VISITOR, vid, 365); }
      return vid;
    });
  }

  function getSessionId() {
    return _c('sid', function() {
      try {
        var sid = sessionStorage.getItem(STORAGE_SESSION);
        if (!sid) { sid = uuid(); sessionStorage.setItem(STORAGE_SESSION, sid); }
        return sid;
      } catch(e) { return uuid(); }
    });
  }

  // ── UTM attribution ──────────────────────────────────────────────────────────
  function getAttribution() {
    return _c('utm', function() {
      var result = {};
      var search = location.search;
      ['source','medium','campaign','term','content'].forEach(function(k) {
        var m = search.match(new RegExp('[?&]utm_' + k + '=([^&#]*)'));
        if (m) result[k] = decodeURIComponent(m[1].replace(/\+/g, ' '));
      });
      if (Object.keys(result).length) {
        setCookie(COOKIE_ATTR, JSON.stringify(result), 30);
        return result;
      }
      var stored = getCookie(COOKIE_ATTR);
      if (stored) { try { return JSON.parse(stored); } catch(e) {} }
      return null;
    });
  }

  // ── Meta CAPI identifiers ─────────────────────────────────────────────────────
  function getMetaIds() {
    return _c('meta', function() {
      var fbp = getCookie('_fbp');
      if (!fbp) {
        fbp = 'fb.1.' + Date.now() + '.' + Math.floor(Math.random() * 1e10);
        setCookie('_fbp', fbp, 90);
      }
      var fbc = getCookie('_fbc') || null;
      if (!fbc) {
        var fbclid = (location.search.match(/[?&]fbclid=([^&#]*)/) || [])[1];
        if (fbclid) {
          fbc = 'fb.1.' + Date.now() + '.' + fbclid;
          setCookie('_fbc', fbc, 90);
        }
      }
      return { fbp: fbp, fbc: fbc };
    });
  }

  // ── GA4 client ID ────────────────────────────────────────────────────────────
  function getGaClientId() {
    return _c('ga', function() {
      var ga = getCookie('_ga');
      if (ga) {
        var parts = ga.split('.');
        if (parts.length >= 4) return parts[2] + '.' + parts[3];
      }
      return null;
    });
  }

  // ── Pinterest click ID ────────────────────────────────────────────────────────
  function getEpik() {
    return _c('epik', function() {
      var fresh = (location.search.match(/[?&]epik=([^&#]*)/) || [])[1];
      if (fresh) { try { fresh = decodeURIComponent(fresh); } catch(e) {} }
      if (fresh && fresh.length >= 6) { setCookie('_epik', fresh, 90); return fresh; }
      return getCookie('_epik') || null;
    });
  }

  // ── TikTok identifiers ────────────────────────────────────────────────────────
  function getTtclid() {
    return _c('ttclid', function() {
      var fresh = (location.search.match(/[?&]ttclid=([^&#]*)/) || [])[1];
      if (fresh) { try { fresh = decodeURIComponent(fresh); } catch(e) {} }
      if (fresh && fresh.length >= 10) { setCookie('_ettc', fresh, 90); return fresh; }
      return getCookie('_ettc') || null;
    });
  }

  // _ttp NÃO é cacheado: o TikTok pixel o seta de forma assíncrona,
  // então leituras posteriores (add_to_cart, checkout) devem buscar o valor real.
  function getTtp() { return getCookie('_ttp') || null; }

  // ── Google click IDs (gclid + gbraid + wbraid) ───────────────────────────────
  // gbraid/wbraid são os click IDs do iOS 14+ (quando o gclid não é setado).
  // Sem capturá-los, todo o tráfego pago de iPhone fica sem atribuição Google.
  function _decodeClickId(v) {
    if (!v) return null;
    try { v = decodeURIComponent(v); } catch (e) {}
    return v && v.length >= 20 ? v : null;
  }
  function _captureClickId(param, cookieName, cacheKey) {
    return _c(cacheKey, function() {
      var fresh = _decodeClickId((location.search.match(new RegExp('[?&]' + param + '=([^&#]*)')) || [])[1]);
      if (fresh) { setCookie(cookieName, fresh, 90); return fresh; }
      return getCookie(cookieName) || null;
    });
  }
  function getGclid()  { return _captureClickId('gclid',  '_gclid',  'gclid');  }
  function getGbraid() { return _captureClickId('gbraid', '_gbraid', 'gbraid'); }
  function getWbraid() { return _captureClickId('wbraid', '_wbraid', 'wbraid'); }

  // ── Transport (Beacon → fetch → img fallback) ─────────────────────────────────
  function send(payload) {
    var url = API_URL + '/pixel/events';
    var sent = false;
    if (navigator.sendBeacon) {
      try {
        sent = navigator.sendBeacon(url, new Blob([JSON.stringify(payload)], {type:'application/json'}));
      } catch(e) {}
    }
    if (!sent) {
      try {
        fetch(url, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify(payload),
          keepalive: true,
          credentials: 'include'
        }).catch(function(){});
        sent = true;
      } catch(e) {}
    }
    if (!sent) {
      var qs = 'cid=' + encodeURIComponent(CLIENT_ID) + '&et=' + encodeURIComponent(payload.event_type) +
               '&vid=' + encodeURIComponent(payload.visitor_id || '') + '&url=' + encodeURIComponent(payload.page_url || '');
      var img = new Image(1,1);
      img.src = url + '?' + qs;
    }
  }

  // ── Event maps ───────────────────────────────────────────────────────────────
  var META_EVENT_MAP = {
    'pageview':         'PageView',
    'product_viewed':   'ViewContent',
    'add_to_cart':      'AddToCart',
    'checkout_started': 'InitiateCheckout'
  };

  var PIN_EVENT_MAP = {
    'pageview':         'pagevisit',
    'product_viewed':   'pagevisit',
    'add_to_cart':      'addtocart',
    'checkout_started': 'checkout'
  };

  function buildMetaParams(eventType, extra) {
    extra = extra || {};
    if (eventType === 'product_viewed' || eventType === 'add_to_cart') {
      return {
        content_ids:  [String(extra.product_id || '')],
        content_name: extra.product_name,
        content_type: 'product',
        value:        Number(extra.product_price || 0),
        currency:     'BRL'
      };
    }
    if (eventType === 'checkout_started') {
      return { value: Number(extra.cart_total || 0), currency: 'BRL', num_items: Number(extra.item_count || 0) };
    }
    return {};
  }

  function buildPinParams(eventType, extra) {
    extra = extra || {};
    if (eventType === 'product_viewed' || eventType === 'add_to_cart') {
      return { line_items: [{ product_id: String(extra.product_id || ''), product_name: extra.product_name || '', product_price: Number(extra.product_price || 0) }] };
    }
    if (eventType === 'checkout_started') {
      return { value: Number(extra.cart_total || 0), currency: 'BRL', order_quantity: Number(extra.item_count || 0) };
    }
    return {};
  }

  // ── buildPayload ──────────────────────────────────────────────────────────────
  function buildPayload(eventType, eventId, extra) {
    var meta = getMetaIds();
    return {
      client_id:    CLIENT_ID,
      event_type:   eventType,
      event_id:     eventId,
      visitor_id:   getVisitorId(),
      session_id:   getSessionId(),
      page_url:     location.href,
      referrer:     d.referrer || null,
      utm:          getAttribution(),
      timestamp:    new Date().toISOString(),
      fbp:          meta.fbp,
      fbc:          meta.fbc,
      ga_client_id: getGaClientId(),
      gclid:        getGclid(),
      ttclid:       getTtclid(),
      ttp:          getTtp(),
      epik:         getEpik(),
      metadata:     extra || {}
    };
  }

  // ── Track ────────────────────────────────────────────────────────────────────
  function track(eventType, extra) {
    var eventId = uuid();
    send(buildPayload(eventType, eventId, extra));

    var metaName = META_EVENT_MAP[eventType];
    if (metaName && w.fbq) {
      try { w.fbq('track', metaName, buildMetaParams(eventType, extra), {eventID: eventId}); } catch(e) {}
    }

    var pinName = PIN_EVENT_MAP[eventType];
    if (pinName && w.pintrk) {
      try { w.pintrk('track', pinName, buildPinParams(eventType, extra)); } catch(e) {}
    }
  }

  // ── Cart attributes sync ──────────────────────────────────────────────────────
  function syncCartAttributes() {
    var meta = getMetaIds();
    var utm  = getAttribution() || {};
    var attrs = {
      '_etv':          getVisitorId(),
      '_fbp':          meta.fbp || '',
      '_fbc':          meta.fbc || '',
      '_gcid':         getGaClientId() || '',
      '_gclid':        getGclid()  || '',
      '_gbraid':       getGbraid() || '',
      '_wbraid':       getWbraid() || '',
      '_ettc':         getTtclid() || '',
      '_ttp':          getTtp()    || '',
      '_epik':         getEpik()   || '',
      '_fblogin':      getCookie('_fblogin') || '',
      '_dob':          getCookie('_dob') || '',
      '_utm_source':   utm.source   || '',
      '_utm_medium':   utm.medium   || '',
      '_utm_campaign': utm.campaign || '',
      '_utm_content':  utm.content  || '',
      '_utm_term':     utm.term     || ''
    };
    var stamp = JSON.stringify(attrs);
    try { if (sessionStorage.getItem('_etcattr') === stamp) return; } catch(e) {}
    try {
      fetch('/cart/update.js', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ attributes: attrs }),
        credentials: 'same-origin',
        keepalive: true
      }).then(function(r) {
        if (r && r.ok) { try { sessionStorage.setItem('_etcattr', stamp); } catch(e) {} }
      }).catch(function(){});
    } catch(e) {}
  }

  // ── Meta Pixel ────────────────────────────────────────────────────────────────
  if (META_PIXEL_ID) {
    !function(f,b,e,v,n,t,s){
      if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s);
    }(w,d,'script','https://connect.facebook.net/en_US/fbevents.js');
    w.fbq('init', META_PIXEL_ID);
  }

  // ── TikTok Pixel ─────────────────────────────────────────────────────────────
  // Stub pattern obrigatório: ttq.load() associa o pixel ID, ttq.page() dispara
  // PageView e inicia o processo de geração do cookie _ttp.
  if (TIKTOK_PIXEL_ID) {
    !function(w,d,t){
      w.TiktokAnalyticsObject=t;var ttq=w[t]=w[t]||[];
      ttq.methods=['page','track','identify','instances','debug','on','off','once',
                   'ready','alias','group','enableCookie','disableCookie',
                   'holdConsent','revokeConsent','grantConsent'];
      ttq.setAndDefer=function(obj,m){obj[m]=function(){obj.push([m].concat(Array.prototype.slice.call(arguments,0)));};};
      for(var i=0;i<ttq.methods.length;i++)ttq.setAndDefer(ttq,ttq.methods[i]);
      ttq.instance=function(id){var e=ttq._i[id]||[];for(var n=0;n<ttq.methods.length;n++)ttq.setAndDefer(e,ttq.methods[n]);return e;};
      ttq.load=function(id,opts){
        var src='https://analytics.tiktok.com/i18n/pixel/events.js';
        ttq._i=ttq._i||{};ttq._i[id]=[];ttq._i[id]._u=src;
        ttq._t=ttq._t||{};ttq._t[id]=+new Date();
        ttq._o=ttq._o||{};ttq._o[id]=opts||{};
        var s=d.createElement('script');s.type='text/javascript';s.async=!0;
        s.src=src+'?sdkid='+id+'&lib='+t;
        var f=d.getElementsByTagName('script')[0];f.parentNode.insertBefore(s,f);
      };
      ttq.load(TIKTOK_PIXEL_ID);
      ttq.page();
    }(w,d,'ttq');
  }

  // ── Pinterest Tag ─────────────────────────────────────────────────────────────
  // Enhanced match com email do cliente logado melhora match rate no CAPI.
  if (PINTEREST_TAG_ID) {
    !function(e){
      if(!w.pintrk){w.pintrk=function(){w.pintrk.queue.push(Array.prototype.slice.call(arguments));};
      var n=w.pintrk;n.queue=[];n.version='3.0';
      var t=d.createElement('script');t.async=!0;t.src=e;
      var r=d.getElementsByTagName('script')[0];r.parentNode.insertBefore(t,r);}
    }('https://s.pinimg.com/ct/core.js');
    {% if customer %}
    w.pintrk('load', PINTEREST_TAG_ID, { em: {{ customer.email | json }} });
    {% else %}
    w.pintrk('load', PINTEREST_TAG_ID);
    {% endif %}
    w.pintrk('page');
  }

  // ── Google Ads remarketing (opcional) ────────────────────────────────────────
  if (GOOGLE_ADS_AW_ID) {
    w.dataLayer = w.dataLayer || [];
    function gtag() { w.dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', GOOGLE_ADS_AW_ID, {'send_page_view': false, 'allow_enhanced_conversions': true});
    var gtagScript = d.createElement('script');
    gtagScript.async = true;
    gtagScript.src = 'https://www.googletagmanager.com/gtag/js?id=' + GOOGLE_ADS_AW_ID;
    d.head.appendChild(gtagScript);
  }

  // ── API pública ───────────────────────────────────────────────────────────────
  w.ET = { track: track, getVisitorId: getVisitorId, getSessionId: getSessionId };

  // ── Pageview + cart sync ──────────────────────────────────────────────────────
  function onReady() {
    track('pageview');
    syncCartAttributes();
  }
  if (d.readyState === 'loading') {
    d.addEventListener('DOMContentLoaded', onReady);
  } else {
    onReady();
  }

  // ── Eventos Shopify ──────────────────────────────────────────────────────────

  {% if template.name == 'product' %}
  track('product_viewed', {
    product_id:       '{{ product.id }}',
    product_name:     {{ product.title | json }},
    product_sku:      '{{ product.selected_or_first_available_variant.sku }}',
    product_price:    {{ product.selected_or_first_available_variant.price | divided_by: 100.0 }},
    product_category: {{ product.type | json }},
    variant_id:       '{{ product.selected_or_first_available_variant.id }}'
  });
  {% endif %}

  d.addEventListener('click', function(e) {
    var tgt = e.target;
    if (tgt.closest('[name="add"],[data-add-to-cart],.add-to-cart,#AddToCart,button[type="submit"].product-form__submit')) {
      {% if template.name == 'product' %}
      track('add_to_cart', {
        product_id:    '{{ product.id }}',
        product_name:  {{ product.title | json }},
        product_price: {{ product.selected_or_first_available_variant.price | divided_by: 100.0 }},
        variant_id:    '{{ product.selected_or_first_available_variant.id }}'
      });
      {% else %}
      track('add_to_cart', {});
      {% endif %}
      setTimeout(syncCartAttributes, 300);
    }
    {% if template.name == 'cart' %}
    if (tgt.closest('[name="checkout"],.cart__checkout,#CartSubmit,[data-cart-checkout]')) {
      track('checkout_started', {
        cart_total: {{ cart.total_price | divided_by: 100.0 }},
        item_count: {{ cart.item_count }},
        cart_token: '{{ cart.token }}'
      });
    }
    {% endif %}
  });

  // ── EMQ: Facebook Login ID (+8%) + Date of Birth (+6%) ───────────────────────

  function captureFacebookLoginId() {
    if (typeof FB !== 'undefined') {
      try {
        FB.getLoginStatus(function(response) {
          if (response.status === 'connected') {
            var userId = response.authResponse.userID;
            if (userId) { setCookie('_fblogin', userId, 90); injectSingleAttribute('_fblogin', userId); }
          }
        });
      } catch(e) {}
    }
  }

  function captureDateOfBirth() {
    var patterns = ['birth_date','dob','date_of_birth','birthDate','birth-date'];
    for (var i = 0; i < patterns.length; i++) {
      var input = d.querySelector('input[name*="' + patterns[i] + '"]');
      if (input && input.value) {
        var dob = normalizeDOB(input.value);
        if (dob) { setCookie('_dob', dob, 90); injectSingleAttribute('_dob', dob); return; }
      }
    }
  }

  function normalizeDOB(value) {
    var cleaned = value.replace(/\D/g, '');
    if (cleaned.length === 8) return cleaned;
    var parts = value.match(/(\d{1,4})[\/\-](\d{1,2})[\/\-](\d{1,4})/);
    if (parts) {
      var year = parts[3], month = parts[1], day = parts[2];
      if (parseInt(year) > 31) return year + padStart(month,2,'0') + padStart(day,2,'0');
      return parts[3] + padStart(month,2,'0') + padStart(day,2,'0');
    }
    return null;
  }

  function padStart(str, length, char) {
    str = String(str);
    while (str.length < length) str = char + str;
    return str;
  }

  function injectSingleAttribute(key, value) {
    if (!value) return;
    var attrs = {};
    attrs[key] = String(value).substring(0, 1000);
    try {
      fetch('/cart/update.js', {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ attributes: attrs }), credentials: 'same-origin', keepalive: true
      }).catch(function(){});
    } catch(e) {}
  }

  if (d.readyState === 'loading') {
    d.addEventListener('DOMContentLoaded', function() {
      setTimeout(captureFacebookLoginId, 500);
      setTimeout(captureDateOfBirth, 500);
    });
  } else {
    setTimeout(captureFacebookLoginId, 500);
    setTimeout(captureDateOfBirth, 500);
  }

  d.addEventListener('change', function(e) {
    var name = (e.target.name || '').toLowerCase();
    if (name.indexOf('birth') !== -1 || name.indexOf('dob') !== -1 || name.indexOf('date') !== -1) {
      captureDateOfBirth();
    }
  }, true);

  d.addEventListener('submit', function(e) {
    if (e.target && e.target.action && e.target.action.indexOf('/checkout') !== -1) {
      captureFacebookLoginId();
      captureDateOfBirth();
      syncCartAttributes();
    }
  }, true);

  // ── Purchase — thank-you page ─────────────────────────────────────────────────
  // event_id = sha256("purchase_shopify_" + order_id) — igual ao backend.
  // Meta/TikTok/Pinterest deduplicam browser ↔ CAPI pelo mesmo event_id.
  var PURCHASE_KEY = '_etpurchase';

  function sha256Hex(str) {
    if (w.crypto && w.crypto.subtle && w.TextEncoder) {
      var enc = new TextEncoder().encode(str);
      return w.crypto.subtle.digest('SHA-256', enc).then(function(buf) {
        var arr = new Uint8Array(buf), hex = '';
        for (var i = 0; i < arr.length; i++) hex += ('0' + arr[i].toString(16)).slice(-2);
        return hex;
      });
    }
    return Promise.resolve('purchase_browser_' + str);
  }

  function isThankYouPage() {
    return /\/(thank[-_ ]?you|obrigado|orders\/[^/]+|pedido-confirmado|order-confirmation)/i.test(location.pathname);
  }

  function alreadyFiredPurchase(orderId) {
    try { var ids = JSON.parse(localStorage.getItem(PURCHASE_KEY) || '[]'); return ids.indexOf(orderId) >= 0; } catch(e) { return false; }
  }

  function markPurchaseFired(orderId) {
    try {
      var ids = JSON.parse(localStorage.getItem(PURCHASE_KEY) || '[]');
      if (ids.indexOf(orderId) < 0) ids.push(orderId);
      localStorage.setItem(PURCHASE_KEY, JSON.stringify(ids.slice(-50)));
    } catch(e) {}
  }

  function extractOrderDetails() {
    var details = { order_id: null, value: null, currency: 'BRL', items: [] };
    try {
      var s = w.Shopify;
      if (s && s.checkout) {
        details.order_id = s.checkout.order_id ? String(s.checkout.order_id) : null;
        details.value    = s.checkout.total_price != null ? Number(s.checkout.total_price) : null;
        details.currency = s.checkout.currency || 'BRL';
        if (Array.isArray(s.checkout.line_items)) {
          details.items = s.checkout.line_items.map(function(li) {
            return { product_id: String(li.product_id || ''), variant_id: String(li.variant_id || ''),
                     name: li.title, sku: li.sku, price: Number(li.price || 0), quantity: Number(li.quantity || 1) };
          });
        }
      }
      if (!details.order_id) {
        var m = location.pathname.match(/\/orders\/([^/?#]+)/i);
        if (m) details.order_id = m[1];
      }
    } catch(e) {}
    return details;
  }

  function maybeTrackPurchase() {
    if (!isThankYouPage()) return;
    var details = extractOrderDetails();
    if (!details.order_id || alreadyFiredPurchase(details.order_id)) return;

    sha256Hex('purchase_shopify_' + details.order_id).then(function(eventId) {
      var extra = { order_id: details.order_id, value: details.value, currency: details.currency, items: details.items };

      send(buildPayload('purchase', eventId, extra));

      if (w.fbq) {
        try {
          w.fbq('track', 'Purchase', { value: Number(details.value || 0), currency: details.currency || 'BRL',
            content_ids: details.items.map(function(i){ return String(i.product_id); }),
            content_type: 'product', num_items: details.items.length || 1 }, { eventID: eventId });
        } catch(e) {}
      }

      if (w.pintrk) {
        try {
          w.pintrk('track', 'checkout', {
            value: Number(details.value || 0), currency: details.currency || 'BRL',
            order_id: String(details.order_id), order_quantity: details.items.length || 1,
            line_items: details.items.map(function(it) {
              return { product_id: String(it.product_id || ''), product_name: it.name || '',
                       product_price: Number(it.price || 0), product_quantity: Number(it.quantity || 1) };
            })
          });
        } catch(e) {}
      }

      markPurchaseFired(details.order_id);
    });
  }

  if (d.readyState === 'loading') {
    d.addEventListener('DOMContentLoaded', maybeTrackPurchase);
  } else {
    maybeTrackPurchase();
  }

}(window, document));
</script>
