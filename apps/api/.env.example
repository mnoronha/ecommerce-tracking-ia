# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Ecommerce Tracking API"
APP_VERSION="2.1.0"
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Webhook secrets ───────────────────────────────────────────────────────────
# Fallback secret used when a per-client secret is not configured.
# Per-client secrets live in clients.shopify_webhook_secret / woo_webhook_secret.
DEFAULT_WEBHOOK_SECRET=change-me-to-a-strong-random-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use "*" to allow all (dev only).
CORS_ORIGINS=*
# CORS_ORIGINS=https://mystore.com,https://admin.mystore.com

# ── Anthropic (AI Insights) ──────────────────────────────────────────────────
# Used by services/ai_analyst.py to generate weekly reports and recommendations.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── SMTP (relatórios semanais por email) ─────────────────────────────────────
# Used by services/alerts.py and services/smtp.py.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Meta CAPI ─────────────────────────────────────────────────────────────────
# Test event code from Events Manager — remover após validação em produção.
META_TEST_EVENT_CODE=

# ── Meta OAuth (Facebook Login for Business) ─────────────────────────────────
# Cria o app em https://developers.facebook.com → My Apps → Business type.
# Compartilhado entre todos os clientes — registrado uma vez no Meta App.
# Required permissions: ads_management, ads_read, business_management
META_APP_ID=
META_APP_SECRET=

# ── Google Ads Conversion API ─────────────────────────────────────────────────
# Agency-level credentials shared across all clients.
# Per-client refresh_token is captured via OAuth flow at /api/google-ads/oauth/start.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_OAUTH_CLIENT_ID=
GOOGLE_ADS_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_MANAGER_ID=
