<script>
(function(w,d){'use strict';var CLIENT_ID='lk-sneakers';var API_URL='https://ecommerce-tracking-ia-production.up.railway.app';var META_PIXEL_ID='1018779385487104';var COOKIE_VISITOR='_etv';var COOKIE_ATTR='_eta';var STORAGE_SESSION='_ets';function setCookie(name,value,days){var expires='';if(days){var exp=new Date();exp.setTime(exp.getTime()+days*864e5);expires='; expires='+exp.toUTCString();}var domain='';try{var parts=location.hostname.split('.');if(parts.length>=2)domain='; domain=.'+parts.slice(-2).join('.');}catch(e){}d.cookie=name+'='+encodeURIComponent(value)+expires+'; path=/'+domain+'; SameSite=Lax';}function getCookie(name){var match=d.cookie.match(new RegExp('(?:^|;\\s*)'+name+'=([^;]*)'));return match?decodeURIComponent(match[1]):null;}function uuid(){return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g,function(c){var r=Math.random()*16|0;return(c==='x'?r:(r&0x3)|0x8).toString(16);});}function getVisitorId(){var vid=getCookie(COOKIE_VISITOR);if(!vid){vid=uuid();setCookie(COOKIE_VISITOR,vid,365);}return vid;}function getSessionId(){try{var sid=sessionStorage.getItem(STORAGE_SESSION);if(!sid){sid=uuid();sessionStorage.setItem(STORAGE_SESSION,sid);}return sid;}catch(e){return uuid();}}function getAttribution(){var result={};var search=location.search;['source','medium','campaign','term','content'].forEach(function(k){var m=search.match(new RegExp('[?&]utm_'+k+'=([^&#]*)'));if(m)result[k]=decodeURIComponent(m[1].replace(/\+/g,' '));});if(Object.keys(result).length){setCookie(COOKIE_ATTR,JSON.stringify(result),30);return result;}var stored=getCookie(COOKIE_ATTR);if(stored){try{return JSON.parse(stored);}catch(e){}}return null;}function getMetaIds(){var fbp=getCookie('_fbp');if(!fbp){fbp='fb.1.'+Date.now()+'.'+Math.floor(Math.random()*1e10);setCookie('_fbp',fbp,90);}var fbc=getCookie('_fbc')||null;if(!fbc){var fbclid=(location.search.match(/[?&]fbclid=([^&#]*)/)||[])[1];if(fbclid){fbc='fb.1.'+Date.now()+'.'+fbclid;setCookie('_fbc',fbc,90);}}return{fbp:fbp,fbc:fbc};}function getGaClientId(){var ga=getCookie('_ga');if(ga){var parts=ga.split('.');if(parts.length>=4)return parts[2]+'.'+parts[3];}return null;}function getGclid(){var gclid=(location.search.match(/[?&]gclid=([^&#]*)/)||[])[1];if(gclid){setCookie('_gclid',gclid,90);return gclid;}return getCookie('_gclid')||null;}function send(payload){var url=API_URL+'/pixel/events';var sent=false;if(navigator.sendBeacon){try{sent=navigator.sendBeacon(url,new Blob([JSON.stringify(payload)],{type:'application/json'}));}catch(e){}}if(!sent){try{fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload),keepalive:true}).catch(function(){});sent=true;}catch(e){}}if(!sent){var qs='cid='+encodeURIComponent(CLIENT_ID)+'&et='+encodeURIComponent(payload.event_type)+'&vid='+encodeURIComponent(payload.visitor_id||'')+'&url='+encodeURIComponent(payload.page_url||'');var img=new Image(1,1);img.src=API_URL+'/pixel/events?'+qs;}}var META_EVENT_MAP={'pageview':'PageView','product_viewed':'ViewContent','add_to_cart':'AddToCart','checkout_started':'InitiateCheckout'};function buildMetaParams(eventType,extra){extra=extra||{};if(eventType==='product_viewed'){return{content_ids:[String(extra.product_id||'')],content_name:extra.product_name,content_type:'product',value:Number(extra.product_price||0),currency:'BRL'};}if(eventType==='add_to_cart'){return{content_ids:[String(extra.product_id||'')],content_name:extra.product_name,content_type:'product',value:Number(extra.product_price||0),currency:'BRL'};}if(eventType==='checkout_started'){return{value:Number(extra.cart_total||0),currency:'BRL',num_items:Number(extra.item_count||0)};}return{};}function track(eventType,extra){var meta=getMetaIds();var eventId=uuid();send({client_id:CLIENT_ID,event_type:eventType,event_id:eventId,visitor_id:getVisitorId(),session_id:getSessionId(),page_url:location.href,referrer:d.referrer||null,utm:getAttribution(),timestamp:new Date().toISOString(),fbp:meta.fbp,fbc:meta.fbc,ga_client_id:getGaClientId(),gclid:getGclid(),metadata:extra||{}});var metaName=META_EVENT_MAP[eventType];if(metaName&&w.fbq){try{w.fbq('track',metaName,buildMetaParams(eventType,extra),{eventID:eventId});}catch(e){}}}function syncCartAttributes(){var meta=getMetaIds();var attrs={'_etv':getVisitorId(),'_fbp':meta.fbp||'','_fbc':meta.fbc||'','_gcid':getGaClientId()||'','_gclid':getGclid()||'','_fblogin':getCookie('_fblogin')||'','_dob':getCookie('_dob')||''};var stamp=JSON.stringify(attrs);try{if(sessionStorage.getItem('_etcattr')===stamp)return;}catch(e){}try{fetch('/cart/update.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({attributes:attrs}),credentials:'same-origin',keepalive:true}).then(function(r){if(r&&r.ok){try{sessionStorage.setItem('_etcattr',stamp);}catch(e){}}}).catch(function(){});}catch(e){}}if(META_PIXEL_ID){!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s);}(w,d,'script','https://connect.facebook.net/en_US/fbevents.js');w.fbq('init',META_PIXEL_ID);}w.ET={track:track,getVisitorId:getVisitorId,getSessionId:getSessionId};function onReady(){track('pageview');syncCartAttributes();}if(d.readyState==='loading'){d.addEventListener('DOMContentLoaded',onReady);}else{onReady();}{% if template.name == 'product' %}track('product_viewed',{product_id:'{{ product.id }}',product_name:{{ product.title | json }},product_sku:'{{ product.selected_or_first_available_variant.sku }}',product_price:{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }},product_category:{{ product.type | json }},variant_id:'{{ product.selected_or_first_available_variant.id }}'});{% endif %}d.addEventListener('click',function(e){var tgt=e.target;if(tgt.closest('[name="add"],[data-add-to-cart],.add-to-cart,#AddToCart,button[type="submit"].product-form__submit')){{% if template.name == 'product' %}track('add_to_cart',{product_id:'{{ product.id }}',product_name:{{ product.title | json }},product_price:{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }},variant_id:'{{ product.selected_or_first_available_variant.id }}'});{% else %}track('add_to_cart',{});{% endif %}setTimeout(syncCartAttributes,300);}{% if template.name == 'cart' %}if(tgt.closest('[name="checkout"],.cart__checkout,#CartSubmit,[data-cart-checkout]')){track('checkout_started',{cart_total:{{ cart.total_price | divided_by: 100.0 }},item_count:{{ cart.item_count }},cart_token:'{{ cart.token }}'});}{% endif %}});function captureFacebookLoginId(){if(typeof FB!=='undefined'){try{FB.getLoginStatus(function(response){if(response.status==='connected'){var userId=response.authResponse.userID;if(userId){console.log('[EMQ] Facebook Login ID captured:',userId);setCookie('_fblogin',userId,90);injectSingleAttribute('_fblogin',userId);}}});}catch(e){console.log('[EMQ] FB.getLoginStatus error:',e.message);}}}function captureDateOfBirth(){var dobPatterns=['birth_date','dob','date_of_birth','birthDate','birth-date'];for(var i=0;i<dobPatterns.length;i++){var input=d.querySelector('input[name*="'+dobPatterns[i]+'"]');if(input&&input.value){var dob=normalizeDOB(input.value);if(dob){console.log('[EMQ] DOB captured:',dob);setCookie('_dob',dob,90);injectSingleAttribute('_dob',dob);return;}}}}function normalizeDOB(value){var cleaned=value.replace(/\D/g,'');if(cleaned.length===8)return cleaned;var parts=value.match(/(\d{1,4})[\/\-](\d{1,2})[\/\-](\d{1,4})/);if(parts){var year=parts[3],month=parts[1],day=parts[2];if(parseInt(year)>31){return year+padStart(month,2,'0')+padStart(day,2,'0');}else{return parts[3]+padStart(month,2,'0')+padStart(day,2,'0');}}return null;}function padStart(str,length,char){str=String(str);while(str.length<length)str=char+str;return str;}function injectSingleAttribute(key,value){if(!value)return;var attrs={};attrs[key]=String(value).substring(0,1000);try{fetch('/cart/update.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({attributes:attrs}),credentials:'same-origin',keepalive:true}).catch(function(){});}catch(e){}}if(d.readyState==='loading'){d.addEventListener('DOMContentLoaded',function(){setTimeout(captureFacebookLoginId,500);setTimeout(captureDateOfBirth,500);});}else{setTimeout(captureFacebookLoginId,500);setTimeout(captureDateOfBirth,500);}d.addEventListener('change',function(e){var name=(e.target.name||'').toLowerCase();if(name.includes('birth')||name.includes('dob')||name.includes('date')){captureDateOfBirth();}},true);d.addEventListener('submit',function(e){if(e.target&&e.target.action&&e.target.action.includes('/checkout')){captureFacebookLoginId();captureDateOfBirth();syncCartAttributes();}},true);}(window,document));
</script>